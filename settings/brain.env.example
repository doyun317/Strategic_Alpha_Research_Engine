# Copy to brain.env and customize for local/private Brain integration.

SAE_BRAIN_BASE_URL=https://api.worldquantbrain.com
SAE_BRAIN_USERNAME=your.worldquant@email
SAE_BRAIN_PASSWORD=your_worldquant_password
SAE_BRAIN_SUBMIT_TIMEOUT_SECONDS=30
SAE_BRAIN_POLL_INTERVAL_SECONDS=15
SAE_BRAIN_MAX_POLLS=120
