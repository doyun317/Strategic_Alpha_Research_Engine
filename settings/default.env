# Strategic Alpha Research Engine default settings
# Keep only shareable, non-secret defaults here.

SAE_ENV=development
SAE_LOG_LEVEL=INFO
SAE_REGION=USA
SAE_UNIVERSE=TOP3000
SAE_DEFAULT_TEST_PERIOD=P1Y0M0D
SAE_SIMULATION_DELAY=1
SAE_SIMULATION_NEUTRALIZATION=subindustry
SAE_AUTOPILOT_TARGET_PACKET_COUNT=20
SAE_AUTOPILOT_PACKET_TOP_K=20
SAE_AUTOPILOT_MIN_QUEUE_DEPTH=5
SAE_AUTOPILOT_IDLE_ROUNDS=10
SAE_AUTOPILOT_MAX_AGENDAS=200
SAE_AUTOPILOT_MAX_SIMULATIONS=500
SAE_AUTOPILOT_AUTO_APPROVE=true
SAE_AUTOPILOT_PACKET_MIN_STAGE=robust_candidate
